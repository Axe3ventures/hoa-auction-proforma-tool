# Copy this file to .env.local and fill in your Google credentials.
# Until these are set, both pages read local sample data from data/auction-sample.json.
#
# Pick ONE of the two auth options below (OAuth is recommended if you don't
# already have a service account JSON key — see SETUP.md for the full steps
# on either path).

# ---- Option A: OAuth (your own Google account, no sharing step needed) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Obtained by visiting /api/oauth/start locally and approving access — see
# SETUP.md "Connect via OAuth instead".
GOOGLE_OAUTH_REFRESH_TOKEN=

# ---- Option B: Service account JSON key ----
# NOTE: the "Purchased" checkbox writes back to a "Purchased" column on the sheet,
# so the service account must be shared on the sheet as an Editor (not just Viewer).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private_key from the downloaded JSON key, keeping the \n escape sequences.
GOOGLE_PRIVATE_KEY=

# ---- Required either way ----
GOOGLE_SHEET_ID=

# Both deal types read from the same spreadsheet (GOOGLE_SHEET_ID) but different tabs.
# Sheriff Sales tab name + range:
GOOGLE_SHEET_RANGE_SHERIFF=Auction!A1:Z1000
# NTS (Trustee Sale) tab name + range — add a second tab named "NTS" with the same
# column headers as the Auction tab:
GOOGLE_SHEET_RANGE_NTS=NTS!A1:Z1000
